# Optional - for enhanced features
USDA_API_KEY=your_usda_key_here
LANGSMITH_API_KEY=your_langsmith_key_here
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=guzzlers-n-dragons

# Database
DATABASE_URL=sqlite:///data/ingredients.db

# Vector Store
CHROMA_PERSIST_DIR=data/chroma

# App
HOST=0.0.0.0
PORT=8000
DEBUG=false
SQL_ECHO=false
# CORS: JSON array of allowed frontend origins for credentialed requests.
# Development: ["http://localhost:5173"]
# Production: replace with your real frontend URL(s), e.g. ["https://app.example.com"]
# Do NOT use ["*"] — browsers reject wildcard + credentials.
CORS_ORIGINS=["http://localhost:5173"]

# LLM
LLM_MODEL=ollama:gemma4:31b-cloud
LLM_TEMPERATURE=0.7

# Embeddings
EMBEDDING_MODEL=nomic-embed-text